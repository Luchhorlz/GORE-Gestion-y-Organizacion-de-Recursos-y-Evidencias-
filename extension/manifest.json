{
  "manifest_version": 3,
  "name": "GORE - Captura de audios de WhatsApp",
  "version": "1.2.0",
  "description": "Captura localmente notas de voz del chat abierto y crea un paquete verificable para GORE.",
  "host_permissions": ["https://web.whatsapp.com/*"],
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["vendor/jszip.min.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
